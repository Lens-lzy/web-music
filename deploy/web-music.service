[Unit]
Description=web-music private FM
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=webmusic
Group=webmusic
WorkingDirectory=/opt/web-music/app
EnvironmentFile=/etc/web-music/web-music.env
ExecStart=/usr/bin/node server/index.js
Restart=on-failure
RestartSec=3
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=full
ProtectHome=true
ReadWritePaths=/var/lib/web-music

[Install]
WantedBy=multi-user.target
